# ── Vault (loads DB_USER + DB_PASS at startup) ──────────────────────────────
VAULT_URL=https://your-vault-host/api/secrets/mudnews
VAULT_BEARER=your-bearer-token

# ── Web UI JWT signing secret ───────────────────────────────────────────────
APP_SECRET_KEY=change-this-to-at-least-32-random-characters

# ── API key (used by Alexa Lambda and N8N to call backend) ──────────────────
ALEXA_API_KEY=change-this-to-a-random-string

# ── Database (host + name set in docker-compose.yml; user/pass from vault) ──
# DB_HOST=postgres-pi      (set in docker-compose.yml)
# DB_NAME=feeds_db         (set in docker-compose.yml — shared with mudfeeds)

# ── AI scorer (POST /mudnews/score-feeds and /n8n/score-batch) ──────────────
# Default: local Ollama scores one article at a time.
AI_SCORER_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:14b-8k
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=180

# Optional later provider: Gemini keeps the batch-scoring code path.
# AI_SCORER_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT=120
# GEMINI_RETRIES=3          # retries on 503 (model overloaded) before skipping a batch
