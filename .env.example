# ── Vault (loads DB_USER + DB_PASS at startup) ──────────────────────────────
VAULT_URL=https://your-vault-host/api/secrets/mudnews
VAULT_BEARER=your-bearer-token

# ── Session auth (web UI cookie signing) ────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string

# ── Web UI password (single shared password for all users) ──────────────────
APP_PASSWORD=change-this

# ── API key (used by Alexa Lambda and N8N to call backend) ──────────────────
ALEXA_API_KEY=change-this-to-a-random-string

# ── Database (host + name set in docker-compose.yml; user/pass from vault) ──
# DB_HOST=postgres-pi      (set in docker-compose.yml)
# DB_NAME=feeds_db         (set in docker-compose.yml — shared with mudfeeds)
